# GitHub Personal Access Token (required)
# Needs public_repo scope for API access to public repos
# Rate limit: 5,000 requests/hour with PAT
GH_TOKEN=ghp_your_personal_access_token

# Slack Incoming Webhook URL (optional)
# Used for deployment change notifications — default for all cities
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Per-city Slack webhook overrides (optional)
# Set these to route notifications for specific cities to dedicated channels.
# Each URL should be a separate Slack Incoming Webhook pointed at the desired channel.
# Cities without a specific webhook fall back to SLACK_WEBHOOK_URL above.
# SLACK_WEBHOOK_URL_ESPOO=
# SLACK_WEBHOOK_URL_TAMPERE_REGION=
# SLACK_WEBHOOK_URL_OULU=
# SLACK_WEBHOOK_URL_TURKU=

# Slack webhooks for repo change announcements (optional)
# Separate from deployment notifications — announces newly merged PRs to tracked repos.
# Core repo changes go to one channel, each wrapper repo to its own channel.
# SLACK_CHANGE_WEBHOOK_CORE=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
# SLACK_CHANGE_WEBHOOK_TAMPERE_REGION=
# SLACK_CHANGE_WEBHOOK_OULU=
# SLACK_CHANGE_WEBHOOK_TURKU=

# Staging/test instances (optional, JSON array)
# Configures which staging environments to monitor.
# See specs/002-remove-staging-urls/quickstart.md for full format reference.
# Example (replace domains with real staging domains):
# STAGING_INSTANCES=[{"cityGroupId":"espoo","envId":"espoo-staging","instances":[{"name":"Espoo Staging","domain":"staging.example.test"}]}]
STAGING_INSTANCES=

# Oulu staging HTTP basic auth (optional)
# Required if Oulu staging is included in STAGING_INSTANCES with authEnvPrefix: "OULU_STAGING"
OULU_STAGING_USER=
OULU_STAGING_PASS=

# Data directory (optional)
# Defaults to .data/ locally and data/ in CI (detected via CI env var).
# Set to "data" to force writing to the tracked directory locally.
# DATA_DIR=

# Dry run mode (optional)
# Set to "true" to skip data file commits and Slack notifications
DRY_RUN=false
