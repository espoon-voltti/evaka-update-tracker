# GitHub Personal Access Token (required)
# Needs public_repo scope for API access to public repos
# Rate limit: 5,000 requests/hour with PAT
GH_TOKEN=ghp_your_personal_access_token

# Slack Incoming Webhook URL (optional)
# Used for deployment change notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Staging/test instances (optional, JSON array)
# Configures which staging environments to monitor.
# See specs/002-remove-staging-urls/quickstart.md for full format reference.
# Example (replace domains with real staging domains):
# STAGING_INSTANCES=[{"cityGroupId":"espoo","envId":"espoo-staging","instances":[{"name":"Espoo Staging","domain":"staging.example.test"}]}]
STAGING_INSTANCES=

# Oulu staging HTTP basic auth (optional)
# Required if Oulu staging is included in STAGING_INSTANCES with authEnvPrefix: "OULU_STAGING"
OULU_STAGING_USER=
OULU_STAGING_PASS=

# Dry run mode (optional)
# Set to "true" to skip data file commits and Slack notifications
DRY_RUN=false
