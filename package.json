{
  "name": "evaka-update-tracker",
  "version": "1.0.0",
  "description": "Track eVaka deployment status across cities and environments",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "screenshot": "npx tsx scripts/screenshot.ts",
    "backfill-labels": "npx tsx scripts/backfill-labels.ts",
    "capture-views": "npx tsx scripts/capture-views.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "axios": "1.16.1",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "eslint": "10.4.0",
    "nock": "14.0.15",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
